# Local development — call Railway API directly (localhost is allowed by backend CORS)
VITE_API_URL=https://inboxhire-production.up.railway.app

# Vercel production — leave VITE_API_URL empty and use vercel.json /api proxy instead:
# VITE_API_URL=
# VITE_OAUTH_BASE_URL=https://inboxhire-production.up.railway.app
